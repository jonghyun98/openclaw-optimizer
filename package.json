{
  "name": "clawpilot",
  "version": "0.1.0",
  "description": "OpenClaw Intelligent Fallback Optimizer & Dashboard",
  "main": ".vite/build/index.js",
  "private": true,
  "scripts": {
    "build:main": "vite build --config vite.main.config.ts",
    "build:preload": "vite build --config vite.preload.config.ts",
    "build:electron": "npm run build:main && npm run build:preload",
    "start": "npm run build:electron && concurrently -k \"vite --config vite.renderer.config.ts src/renderer --port 5173\" \"wait-on http://localhost:5173 && NODE_PATH=$PWD/node_modules electron .\"",
    "dev": "npm start",
    "forge:start": "NODE_PATH=./node_modules electron-forge start",
    "package": "electron-forge package",
    "make": "electron-forge make",
    "lint": "eslint src/",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@electron-forge/cli": "^7.6.0",
    "@electron-forge/maker-dmg": "^7.6.0",
    "@electron-forge/maker-zip": "^7.6.0",
    "@electron-forge/plugin-vite": "^7.6.0",
    "@types/better-sqlite3": "^7.6.12",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^4.3.0",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.2.1",
    "electron": "^34.0.0",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "vitest": "^3.0.0",
    "wait-on": "^9.0.4"
  },
  "dependencies": {
    "@tanstack/react-virtual": "^3.11.0",
    "better-sqlite3": "^11.7.0",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.38.4",
    "electron-squirrel-startup": "^1.0.1",
    "lucide-react": "^0.469.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.1.0",
    "recharts": "^2.15.0",
    "sql.js": "^1.14.1",
    "tailwind-merge": "^2.6.0",
    "ws": "^8.18.0",
    "zustand": "^5.0.0"
  }
}
